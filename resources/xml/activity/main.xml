<brls:AppletFrame
        iconInterpolation="linear"
        headerHidden="true"
        footerHidden="false">
    <brls:Box
            axis="column"
            width="100%"
            height="100%">
        <AutoTabFrame
                id="main/tabFrame"
                grow="1"
                tabBackgroundColor="@theme/color/grey_1"
                tabItemActiveTextColor="@theme/color/chzzk"
                disableNavigationDown="true"
                defaultTab="0"
                sidebarPosition="left">

            <Tab label=""
                 fontSize="18"
                 icon="@res/svg/live.svg"
                 iconActivate="@res/svg/live_activate.svg">
                <LiveTab/>
            </Tab>

            <Tab label=""
                 fontSize="18"
                 icon="@res/svg/following.svg"
                 iconActivate="@res/svg/following_activate.svg">
                <FollowingTab/>
            </Tab>

            <Tab label=""
                 fontSize="18"
                 icon="@res/svg/category.svg"
                 iconActivate="@res/svg/category_activate.svg">
                <CategoryTab/>
            </Tab>

            <Tab label=""
                 fontSize="18"
                 icon="@res/svg/search.svg"
                 iconActivate="@res/svg/search_activate.svg">
                <SearchTab/>
            </Tab>

            <Tab label=""
                 fontSize="18"
                 focusDown="main/login"
                 icon="@res/svg/vod.svg"
                 iconActivate="@res/svg/vod_activate.svg">
                <VodTab/>
            </Tab>
        </AutoTabFrame>

        <brls:Box
                wireframe="false"
                width="100"
                axis="column"
                justifyContent="center"
                alignItems="center"
                positionType="absolute"
                positionBottom="20">
            <CustomButton
                    id="main/login"
                    focusable="true"
                    highlightCornerRadius="50"
                    cornerRadius="50"
                    marginBottom="10"
                    wireframe="false">
                <SVGImage
                        width="48"
                        height="48"
                        SVG="@res/svg/ico-login.svg"/>
            </CustomButton>

            <CustomButton
                    id="main/setting"
                    focusable="true"
                    highlightCornerRadius="50"
                    cornerRadius="50"
                    wireframe="false">
                <SVGImage
                        width="48"
                        height="48"
                        SVG="@res/svg/ico-setting.svg"/>
            </CustomButton>
        </brls:Box>
    </brls:Box>
</brls:AppletFrame>
