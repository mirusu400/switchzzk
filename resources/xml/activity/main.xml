<brls:AppletFrame footerHidden="false">
    <brls:TabFrame
        title="Switchzzk"
        icon="@res/icon/icon.jpg">

        <brls:Tab label="LIVE" icon="icon/live.png">
            <LiveTab />
        </brls:Tab>

        <brls:Tab label="Following" icon="icon/following.png">
            <FollowingTab />
        </brls:Tab>

        <brls:Tab label="Category" icon="icon/category.png">
            <CategoryTab />
        </brls:Tab>

        <brls:Tab label="Search" icon="icon/search.png">
            <SearchTab />
        </brls:Tab>

        <brls:Tab label="VOD" icon="icon/vod.png">
            <VodTab />
        </brls:Tab>

        <brls:Separator />

        <brls:Tab label="Settings" icon="icon/settings.png">
            <brls:Box
                width="auto"
                height="auto"
                axis="column"
                paddingTop="50"
                paddingBottom="50"
                paddingLeft="75"
                paddingRight="75">

                <brls:Label
                    width="auto"
                    height="auto"
                    text="Switchzzk v0.3.0"
                    fontSize="24" />

                <brls:Label
                    width="auto"
                    height="auto"
                    text="치지직 라이브 스트리밍 for Nintendo Switch"
                    fontSize="16"
                    textColor="#808080"
                    marginTop="10" />

                <brls:Label
                    width="auto"
                    height="auto"
                    text="팔로잉: X 버튼으로 NID_AUT / NID_SES 쿠키 입력"
                    fontSize="14"
                    textColor="#707580"
                    marginTop="20" />

            </brls:Box>
        </brls:Tab>

    </brls:TabFrame>
</brls:AppletFrame>
