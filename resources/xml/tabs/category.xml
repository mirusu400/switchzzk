<brls:Box
    width="auto"
    height="auto"
    axis="column"
    paddingTop="20"
    paddingLeft="20"
    paddingRight="20">

    <brls:Label
        id="cat/status"
        width="auto"
        height="auto"
        text="카테고리"
        fontSize="20"
        textColor="#E1E3DE"
        marginBottom="12" />

    <brls:ScrollingFrame
        id="cat/scroll"
        width="auto"
        grow="1.0">

        <brls:Box
            id="cat/grid"
            width="auto"
            height="auto"
            axis="column" />

    </brls:ScrollingFrame>

</brls:Box>
