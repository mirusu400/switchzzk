<brls:Box
    width="auto"
    height="auto"
    axis="column"
    paddingTop="20"
    paddingLeft="30"
    paddingRight="30">

    <brls:Label
        id="live/status"
        width="auto"
        height="auto"
        text="@i18n/app/loading"
        fontSize="20"
        textColor="#E1E3DE"
        marginBottom="12" />

    <brls:RecyclerFrame
        id="live/recycler"
        width="auto"
        grow="1.0" />

</brls:Box>
