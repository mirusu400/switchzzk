<brls:Box
    width="auto"
    height="56"
    axis="row"
    paddingTop="10"
    paddingBottom="10"
    paddingLeft="16"
    paddingRight="16"
    focusable="true"
    cornerRadius="10"
    backgroundColor="#1E2023"
    marginBottom="6"
    justifyContent="spaceBetween"
    alignItems="center">

    <brls:Label
        id="cat/name"
        width="auto"
        height="auto"
        fontSize="16"
        textColor="#FFFFFF" />

    <brls:Label
        id="cat/viewers"
        width="auto"
        height="auto"
        fontSize="13"
        textColor="#00FFA3" />

</brls:Box>
