<brls:Box
    width="auto"
    height="auto"
    axis="column"
    marginBottom="10"
    paddingLeft="12"
    paddingRight="12"
    paddingTop="10"
    paddingBottom="10"
    focusable="true"
    cornerRadius="12"
    backgroundColor="#1E2023">

    <!-- 썸네일 -->
    <brls:Image
        id="vod/thumbnail"
        width="auto"
        height="130"
        scalingType="fill"
        cornerRadius="8"
        marginBottom="10" />

    <!-- 제목 -->
    <brls:Label
        id="vod/title"
        width="auto"
        height="auto"
        fontSize="15"
        textColor="#FFFFFF" />

    <!-- 채널명 -->
    <brls:Label
        id="vod/channel"
        width="auto"
        height="auto"
        fontSize="12"
        textColor="#00FFA3"
        marginTop="4" />

    <!-- 재생시간 + 조회수 -->
    <brls:Box width="auto" height="auto" axis="row" marginTop="4" justifyContent="spaceBetween">
        <brls:Label
            id="vod/duration"
            width="auto"
            height="auto"
            fontSize="11"
            textColor="#707580" />

        <brls:Label
            id="vod/views"
            width="auto"
            height="auto"
            fontSize="11"
            textColor="#707580" />
    </brls:Box>

</brls:Box>
